# ─── Required ────────────────────────────────────────────────
# Dashboard login password. Server will refuse to start without this.
ADMIN_PASSWORD=change_me_to_something_strong

# ─── Optional ────────────────────────────────────────────────
# HTTP port (default: 3000)
PORT=3000

# Set to "production" behind an HTTPS reverse proxy — adds Secure flag to auth cookie
NODE_ENV=development

# Secret for signing operator session cookies.
# If not set, defaults to SHA-256 of ADMIN_PASSWORD.
# OP_COOKIE_SECRET=another_random_string

# Telegram alerts (optional)
# TELEGRAM_BOT_TOKEN=your_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here
